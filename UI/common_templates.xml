<configs>
	<append xpath="/templates">
		<player_selector depth="1" pos="0,0" width="200" height="32">
			<rect name="${name}" depth="${depth}" pos="${pos}" filter="${filter}" disableautobackground="true" controller="CompareSkills.XUiC_PlayerSelector, CompareSkills">
				<button depth="4" name="prevPlayer" style="icon30px, press" width="${height-2}" height="${height-2}" pos="${Round(height/2, 0)},${Round(-height/2, 0)}" enabled="{hasprevplayer}" sprite="ui_game_symbol_arrow_left" disabledcolor="[lightGrey]" pivot="center" sound="[paging_click]" use_selection_box="false" />
				<rect depth="4" pos="${height},${Round(-height/2, 0)}">
					<sprite name="background" style="icon30px" width="${width-2*height}" height="${height-2}" pivot="left" color="[black]" type="sliced" />
					<label depth="5" text="{compareplayername}" width="${width-2*height}" height="${height-2}" font_size="${height-4}" pivot="left" justify="center" />
				</rect>
				<button depth="4" name="nextPlayer" style="icon30px, press" width="${height-2}" height="${height-2}" pos="${Round(width - height/2, 0)},${Round(-height/2, 0)}" enabled="{hasnextplayer}" sprite="ui_game_symbol_arrow_right" disabledcolor="[lightGrey]" pivot="center" sound="[paging_click]" use_selection_box="false" />
			</rect>
		</player_selector>
	</append>
</configs>